# Run mode
# mock = local demo without Tencent RTC Chat SDK credentials
# tencent = connect support conversations to Tencent RTC Chat SDK
NEXT_PUBLIC_CHAT_MODE=mock

# Tencent RTC Chat SDK
# Get SDKAppID from https://console.trtc.io
NEXT_PUBLIC_TENCENT_SDK_APP_ID=
TENCENT_SDK_SECRET_KEY=
TENCENT_USERSIG_EXPIRE_SECONDS=604800

# Demo users
NEXT_PUBLIC_CUSTOMER_USER_ID=customer_maya
NEXT_PUBLIC_AGENT_USER_ID=support_alex

# Optional AI provider
# Leave blank to use the built-in deterministic triage agent.
# Use any OpenAI-compatible provider by setting AI_BASE_URL + AI_API_KEY + AI_MODEL.
AI_API_KEY=
AI_BASE_URL=
AI_MODEL=gpt-4o-mini
